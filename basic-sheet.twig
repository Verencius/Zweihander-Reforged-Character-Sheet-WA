            {% set attribute_agility_advance_array = attribute_agility_advance_array + 1 %}
        {% endif %}
        {% if attribute(variables, "profession_intermediate_toggle_" ~ j) == true and attribute(variables, "profession_intermediate_bonus_" ~ i) == "Agility" %}
            {% set attribute_agility_advance_array = attribute_agility_advance_array + 1 %}
