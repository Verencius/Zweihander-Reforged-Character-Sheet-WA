<!-- peril threshold calculactions -->
{% set peril_base = attribute_willpower_bonus_final + 3 %}
<!-- weapons peril bonus -->
{% set weapon_pth = 0 %}
{% set weapon_pth_found = [0] %}
{% set hardened_weapon_name = [""] %}
{% for i in 1..4 %}
    {# Fake the break: Only execute if weapon_pth_found[0] is still 0 #}
    {% if weapon_pth_found[0] == 0 and variables["weapon_active_" ~ i] == true %}
        {% set qualities = variables["weapon_qualities_" ~ i]|lower %}
        {% if qualities is not empty and "hardened" in qualities and "ruined" not in qualities %}
            {% set weapon_pth_found = [1] %}
            {% set hardened_weapon_name = [variables["weapon_name_" ~ i]] %}
        {% endif %}
    {% endif %}
{% endfor %}
{% set weapon_pth = weapon_pth_found[0] %}
{% set weapon_pth_name = hardened_weapon_name[0] %}
<!-- peril talents -->
{% set talent_pth_salt = 0 %}
{% for n in 1..3 %}
    {% if variables["profession_basic_toggle_" ~ (15 + n)] == true and "Salt Of The Earth" in variables["profession_basic_talent_" ~ n]|lower
       or variables["profession_intermediate_toggle_" ~ (15 + n)] == true and "Salt Of The Earth" in variables["profession_intermediate_talent_" ~ n]|lower
       or variables["profession_advanced_toggle_" ~ (15 + n)] == true and "Salt Of The Earth" in variables["profession_advanced_talent_" ~ n]|lower %}
        {% set talent_pth_salt = 3 %}
    {% endif %}
{% endfor %}
<!-- peril threshold finalization -->
{% set peril_threshold_adjusted = peril_base + weapon_pth + talent_pth_salt + variables.peril_situational %}
<!-- damage threshold modifiers -->
{% set damage_base = attribute_brawn_bonus_final %}
<!-- armor dth mod -->
{% if variables.armor_qualities is defined and variables.armor_qualities is not empty %}
    {% if "ruined" in variables.armor_qualities|lower %}
        {% set armor_dth_final = 0 %}
    {% elseif "maker's mark" in variables.armor_qualities|lower %}
        {% set armor_dth_final = variables.armor_dth + 1 %}
    {% elseif variables.armor_dd > attribute_brawn_bonus_final %}
        {% set armor_dth_raw = variables.armor_dth - (variables.armor_dd - attribute_brawn_bonus_final) %}
        {% set armor_dth_final = armor_dth_raw > 0 ? armor_dth_raw : 1 %}
    {% else %}
        {% set armor_dth_final = variables.armor_dth %}
    {% endif %}
{% else %}
    {% set armor_dth_final = variables.armor_dth %}
{% endif %}
<!-- weapon dth mod -->
{% set weapon_dth = 0 %}
{% set weapon_dth_found = [0] %}
{% set defensive_weapon_name = [""] %}
{% for i in 1..4 %}
    {# Fake the break: Only execute if weapon_dth_found[0] is still 0 #}
    {% if weapon_dth_found[0] == 0 and variables["weapon_active_" ~ i] == true %}
        {% set qualities = variables["weapon_qualities_" ~ i]|lower %}
        {% if qualities is not empty and "defensive" in qualities and "ruined" not in qualities %}
            {% set weapon_dth_found = [1] %}
            {% set defensive_weapon_name = [variables["weapon_name_" ~ i]] %}
        {% endif %}
    {% endif %}
{% endfor %}
{% set weapon_dth = weapon_dth_found[0] %}
{% set weapon_dth_name = defensive_weapon_name[0] %}
<!-- talent DTH mods -->
{% set talent_dth_end = 0 %}
{% for n in 1..3 %}
    {% if variables.profession_basic_toggle_8 == true and "The End Is Nigh" in variables.profession_basic_profession_talent|lower
       or variables.profession_intermediate_toggle_8 == true and "The End Is Nigh" in variables.profession_intermediate_profession_talent|lower
       or variables.profession_advanced_toggle_8 == true and "The End Is Nigh" in variables.profession_advanced_profession_talent|lower %}
        {% set talent_dth_end = 3 %}
    {% endif %}
{% endfor %}
{% set talent_dth_salt = 0 %}
{% for n in 1..3 %}
    {% if variables["profession_basic_toggle_" ~ (15 + n)] == true and "Salt Of The Earth" in variables["profession_basic_talent_" ~ n]|lower
       or variables["profession_intermediate_toggle_" ~ (15 + n)] == true and "Salt Of The Earth" in variables["profession_intermediate_talent_" ~ n]|lower
       or variables["profession_advanced_toggle_" ~ (15 + n)] == true and "Salt Of The Earth" in variables["profession_advanced_talent_" ~ n]|lower %}
        {% set talent_dth_salt = 1 %}
    {% endif %}
{% endfor %}
<!-- final DTH calculactions -->
{% set damage_threshold_adjusted = damage_base + armor_dth_final + weapon_dth + talent_dth_end + talent_dth_salt + variables.damage_situational %}
<!-- initiative overage tools -->
{% set burden_tools = [] %}
{% for n in 1..6 %}
    {% if variables["supplies_tool_" ~ n] is not empty %}
        {% set burden_tools = burden_tools | merge([1]) %}
    {% endif %}
{% endfor %}
{% set total_tools = burden_tools | length %}
{% set initiative_burden = total_tools > 3 ? total_tools - 3 : 0 %}
<!-- initiative overage wealth -->
{% set wealth_enc = (variables.silver / 1000)|round(0, 'floor') %}
<!-- initiative talents -->
{% set initiative_instincts = 0 %}
{% for n in 1..3 %}
    {% if variables["profession_basic_toggle_" ~ (15 + n)] == true and "instincts" in variables["profession_basic_talent_" ~ n]|lower
       or variables["profession_intermediate_toggle_" ~ (15 + n)] == true and "instincts" in variables["profession_intermediate_talent_" ~ n]|lower
       or variables["profession_advanced_toggle_" ~ (15 + n)] == true and "instincts" in variables["profession_advanced_talent_" ~ n]|lower %}
        {% set initiative_instincts = 1 %}
    {% endif %}
{% endfor %}
<!-- penalty for 4 weapons -->
{% set weapon_count = [] %}
{% for i in 1..4 %}
    {% if variables["weapon_name_" ~ i] is not empty %}
        {% set weapon_count = weapon_count | merge([1]) %}
    {% endif %}
{% endfor %}
{% set initiative_weapon = weapon_count | length > 3 ? 1 : 0 %}
<!-- ancestral talent initiative modifier -->
{% set initiative_ancestral = false %}
{% if variables.profession_basic_toggle_8 == true and "liquid poise" in variables.profession_basic_ancestral_talent|lower
   or variables.profession_intermediate_toggle_8 == true and "liquid poise" in variables.profession_intermediate_ancestral_talent|lower
   or variables.profession_advanced_toggle_8 == true and "liquid poise" in variables.profession_advanced_ancestral_talent|lower %}
    {% set initiative_ancestral = true %}
{% endif %}
<!-- initiative base calculations -->
{% if initiative_ancestral == true and attribute_agility_bonus_final > attribute_perception_bonus_final %}
    {% set initiative_base = attribute_agility_bonus_final + 3 %}
{% else %}
    {% set initiative_base = attribute_perception_bonus_final + 3 %}
{% endif %}
<!-- initiative final calculation -->
{% set initiative_final = initiative_base + initiative_armor + initiative_burden + initiative_weapon + initiative_instincts + variables.burden_penalty + initiative_ancestral + variables.initiative_temporary %}
<!-- end of macros -->
