{% set skill_fellowship_persuasion_value =  variables.attribute_fellowship + ([variables.skill_fellowship_persuasion_10,variables.skill_fellowship_persuasion_20,variables.skill_fellowship_persuasion_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_fellowship_disguise_value =  variables.attribute_fellowship + ([variables.skill_fellowship_disguise_10,variables.skill_fellowship_disguise_20,variables.skill_fellowship_disguise_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_fellowship_guile_value =  variables.attribute_fellowship + ([variables.skill_fellowship_guile_10,variables.skill_fellowship_guile_20,variables.skill_fellowship_guile_30]|reduce((carry, v) => carry + v))*10 %}

<!-- dodge and parry values -->
<!-- current profession selector -->
{% if variables.profession_advanced != "" %}
    {% set profession_current = variables.profession_advanced %}
{% elseif variables.profession_intermediate != "" %}
    {% set profession_current = variables.profession_intermediate %}
{% else %}
    {% set profession_current = variables.profession_basic %}
{% endif %}
<!-- peril threshold calculactions -->
{% set peril_base = attribute_willpower_bonus_final + 3 %}
<!-- weapons peril bonus -->
{% set weapon_pth = 0 %}
{% set weapon_pth_found = [0] %}
{% for i in 1..4 %}
    {% if variables["weapon_active_" ~ i] == true %}
        {% set qualities = variables["weapon_qualities_" ~ i]|lower %}
        {% if qualities is not empty and "hardened" in qualities and "ruined" not in qualities %}
            {% set weapon_pth_found = [1] %}
        {% endif %}
    {% endif %}
{% endfor %}
{% set weapon_pth = weapon_pth_found[0] %}
<!-- peril threshold finalization -->
{% set peril_threshold_adjusted = peril_base + weapon_pth + variables.peril_situational %}
<!-- damage threshold modifiers -->
{% set damage_base = attributes_brawn_bonus_final %}
<!-- armor dth mod -->
{% if variables.armor_qualities is defined and variables.armor_qualities is not empty %}
    {% if "ruined" in variables.armor_qualities|lower %}
        {% set armor_dth_final = 0 %}
    {% elseif "maker's mark" in variables.armor_qualities|lower %}
        {% set armor_dth_final = variables.armor_dth + 1 %}
    {% else %}
        {% set armor_dth_final = variables.armor_dth %}
    {% endif %}
{% else %}
    {% set armor_dth_final = variables.armor_dth %}
{% endif %}
<!-- weapons dth mod -->
{% set weapons_dth = 0 %}
{% set weapons_dth_found = [0] %}
{% for i in 1..4 %}
    {% if variables["weapon_active_" ~ i] == true %}
        {% set qualities = variables["weapon_qualities_" ~ i]|lower %}
        {% if qualities is not empty and "defensive" in qualities and "ruined" not in qualities %}
            {% set weapons_dth_found = [1] %}
        {% endif %}
    {% endif %}
{% endfor %}
{% set weapons_dth = weapons_dth_found[0] %}
<!-- final DTH calculactions -->
{% set damage_threshold_adjusted = damage_base + armor_dth_final + weapon_dth + variables.damage_situational %}
<!-- Weapon stats -->
<!-- end of macros -->
<div id="karta" class="container-fluid">
    <!-- Tabbing -->
    <input class="input-hidden" type="radio" name="tabs" id="tab1" checked/><label for="tab1">Personal</label>
<!-- <input class="input-hidden" type="radio" name="tabs" id="tab3"/><label for="tab3">Attributes & Skills</label> -->
    <input class="input-hidden" type="radio" name="tabs" id="tab4"/><label for="tab4">Traits Talents & Gifts</label>
    <input class="input-hidden" type="radio" name="tabs" id="tab5"/><label for="tab5">Combat Profile</label>
    <input class="input-hidden" type="radio" name="tabs" id="tab6"/><label for="tab6">Trappings</label>
    <input class="input-hidden" type="radio" name="tabs" id="tab7"/><label for="tab7">Magic Profile</label>
    <input class="input-hidden" type="radio" name="tabs" id="tab8"/><label for="tab8">Advancement</label>
    <!-- TAB #1Personal -->
    <div class="tab content1">
        <div class="row">
            <div class="col-sm-12">
                <!-- TAB #1.1 -->
                <div class="row">
                    <div class="col-sm-9 card-content">
                        <div class="row card header">
                            <div class="col-sm-12">
                                <h2>My name is&nbsp;{% if variables.name is defined %}<strong>{{ variables.name}}{% else %}Unknown{% endif %}</strong>
                                <!-- this should loop through 3 different professions and select the highest defined -->
                                and I'm&nbsp;<strong>a&nbsp;{% if profession_current is not empty %}{{ profession_current|title}}{% else %}Survivor{% endif %}</strong></h2>
                            </div>
                            <div class="col-sm-12">
                                I'm&nbsp;<strong>{{ variables.personal_age_group}}&nbsp;{{ variables.personal_ancestry }}&nbsp;{{ variables.personal_gender }}</strong>.&nbsp;I was born in&nbsp;<strong>{{ variables.personal_season_of_birth }}&nbsp;</strong>
                                in the place called&nbsp;<strong>{{ variables.personal_place_of_birth}}</strong>.&nbsp;I was raised in a/an&nbsp;<strong>{{ variables.personal_upbringing}}&nbsp;</strong>home of the&nbsp;<strong>{{ variables.personal_social_class}}&nbsp;</strong>class {% if variables.personal_patron_deity is not empty %} and became a follower of&nbsp;<strong>{{ variables.personal_patron_deity}}</strong>{% endif %}.
                                When you see me  I am of a/an&nbsp;<strong>{{ variables.personal_height}} stature</strong>&nbsp;with a/an&nbsp;<strong>{{ variables.personal_build_type}} build</strong>,<strong>&nbsp;{{ variables.personal_hair_color }} hair</strong>,
                                <strong>&nbsp;{{ variables.personal_eye_color}} eyes</strong>,<strong>&nbsp;{{ variables.personal_complexion}} complexion</strong>&nbsp;and&nbsp;<strong>{{ variables.personal_distinguishing_marks_1 }}</strong>.
                                My life changed the day that{% if variables.personal_brush_with_death is defined and variables.personal_brush_with_death is not empty %}{{ variables.personal_brush_with_death}}{% else %}<i><strong>&nbsp;is shrouded in the fog of war</strong></i>{% endif %}.
                                Yet I lived to tell the tale.
                            </div>
                        </div>
                        <div class="row card">
                            <div class="col-sm-12"><strong>Languages:</strong> {{ variables.personal_language }}</div>
                        </div>
                        <div class="row card">
                            <div class="col-sm-12"><strong>Inner Strength:</strong> {{ variables.alignment_inner_strength }}</div>
                            <div class="col-sm-12 card-info-label"><i>Did you call upon one of your Inner Strengths 5 RP</i></div>
                        </div>
                        <div class="row card">
                            <div class="col-sm-12"><strong>Tragic Flaw:</strong> {{ variables.alignment_tragic_flaw }}</div>
                            <div class="col-sm-12 card-info-label"><i>Did you call upon one of your Tragic Flaws 5 RP</i></div>
                        </div>
                        <div class="row card">
                            <div class="col-sm-12"><strong>In my adventures I have been tained by corruption:</strong>
                            {% for i in 1..9 %}{% if total_corruption >= i %}&nbsp;<i class="fas fa-square"></i> {% else %}&nbsp;<i class="far fa-square"></i>{% endif %}{% endfor %}
                            &nbsp;<strong>Gain Malignancy</strong></div>
                            <div class="col-sm-12"><strong>And the world has left a mark on me:</strong></div>
                            <div class="col-sm-12">{% if malignancies_and_scars is not empty %} {{ variable.malignancies_and_scars |nl2br}}{% else %} ... {% endif %}</div>
                            <div class="col-sm-12"><strong>Permanent Corrupton</strong>&nbsp;{% if permanent_corruption == 0 %} 0 {% else %} {{ permanent_corruption }} {% endif %}</div>
                        </div>
                    </div>    
                    <div class="col-sm-3 card-mt3">{% if variables.imageid is defined and variables.imageid > 0 %}[img:{{variables.imageid}}|nolink]{% endif %} </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-7 card">
                <div class="row">
                    <div class="col-sm-12">
                        <div class="row"><div class="col-sm-12 card-title">Attributes And Skills</div></div>
                        <div class="row">
                            <div class="col-sm-12">
                                <div class="row">
                                    <div class="col-sm-6">
                                        <div class="row">
                                            <div class="col-sm-6"><strong>Primary Attribute</strong></div>                                    
                                            <div class="col-sm-6"><strong>Secondary Attribute</strong></div>
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="row">
                                            <div class="col-sm-4"><strong>Skills</strong></div>
                                            <div class="col-sm-4"><strong>Skill Ranks +10</strong></div>
                                            <div class="col-sm-4"><strong>% Success</strong></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-3">
                                        <div class="row">
                                            <div class="col-sm-8 text-medium">Agility</div>
                                            <div class="col-sm-4 text-medium border-bottom text-center">{{ variables.attribute_agility }}</div>
                                        </div>
                                    </div>
                                    <div class="col-sm-3">
                                        <div class="row">
                                            <div class="col-sm-12">{% for i in 1..6 %}{% if attribute_agility_advance_array >= i %}<i class="fas fa-square-full"></i>{% else %}<i class="far fa-square-full"></i>{% endif %}{% endfor %}</div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-12"><strong>Agility Bonus [AB]: {{ attribute_agility_bonus_final}}</strong></div>
                                        </div>
                                    </div>  
                                    <div class="col-sm-6">
                                        <div class="row">
                                            <div class="col-sm-4"><strong>Athletics</strong></div>
                                            <div class="col-sm-4">{% for i in 1..3 %}{% if skill_coordination_rank_array >= i %}<i class="fas fa-square-full"></i>{% else %}<i class="far fa-square-full"></i>{% endif %}{% endfor %}</div>
                                            <div class="col-sm-4 border-bottom text-center">{{ skill_athletics_total }}%</div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4"><strong>Awareness</strong></div>
                                            <div class="col-sm-4">{% for i in 1..3 %}{% if skill_awareness_rank_array >= i %}<i class="fas fa-square-full"></i>{% else %}<i class="far fa-square-full"></i>{% endif %}{% endfor %}</div>
                                            <div class="col-sm-4 border-bottom text-center">{{ skill_awareness_total }}%</div>
                                        </div>
