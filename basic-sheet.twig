<!-- athletics -->
{% set athletics_count = 0 %}
{% for tier in ['basic', 'intermediate', 'advanced'] %}
    {% for i in 1..6 %}
        {% set skill = attribute(variables, "profession_" ~ tier ~ "_skill_" ~ i)|default('') %}
        {% set toggle = attribute(variables, "profession_" ~ tier ~ "_toggle_" ~ i)|default(0) %}
        
        {% if skill == "Athletics" and toggle == 1 %}
            {% set athletics_count = athletics_count + 1 %}
        {% endif %}
    {% endfor %}
{% endfor %}
{% set athletics_advance = athletics_count > 3 ? 3 : athletics_count %}
{% set skill_athletics_total = attribute_brawn_final + (athletics_advance * 10) %}
