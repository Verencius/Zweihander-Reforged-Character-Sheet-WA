{% endfor %}

<!-- set attribute final bonus calculations -->
{% set attribute_combat_bonus_final = (variables.attribute_combat/10)|round (0,'floor') + variables.attribute_combat_bonus_mod + attribute_combat_advance_array %}
{% set attribute_brawn_bonus_final = (variables.attribute_brawn/10)|round (0,'floor') + variables.attribute_brawn_bonus_mod + attribute_brawn_advance_array %}
{% set attribute_agility_bonus_final = (variables.attribute_agility/10)|round (0,'floor') + variables.attribute_agility_bonus_mod + attribute_agility_advance_array %}
{% set attribute_perception_bonus_final = (variables.attribute_perception/10)|round (0,'floor') + variables.attribute_perception_bonus_mod + attribute_perception_advance_array %}
{% set attribute_intelligence_bonus_final = (variables.attribute_intelligence/10)|round (0,'floor') + variables.attribute_intelligence_bonus_mod + attribute_intelligence_advance_array %}
{% set attribute_willpower_bonus_final = (variables.attribute_willpower/10)|round (0,'floor') + variables.attribute_willpower_bonus_mod + attribute_willpower_advance_array %}
{% set attribute_fellowship_bonus_final = (variables.attribute_fellowship/10)|round (0,'floor') + variables.attribute_fellowship_bonus_mod + attribute_fellowship_advance_array %}

<!-- skill advances value -->
{% set skill_combat_melee_value = variables.attribute_combat + ([variables.skill_combat_melee_10,variables.skill_combat_melee_20,variables.skill_combat_melee_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_combat_ranged_value = variables.attribute_combat + ([variables.skill_combat_ranged_10,variables.skill_combat_ranged_20,variables.skill_combat_ranged_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_combat_blackpowder_value = variables.attribute_combat + ([variables.skill_combat_blackpowder_10,variables.skill_combat_blackpowder_20,variables.skill_combat_blackpowder_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_brawn_athletics_value = variables.attribute_brawn + ([variables.skill_brawn_athletics_10,variables.skill_brawn_athletics_20,variables.skill_brawn_athletics_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_brawn_handling_value = variables.attribute_brawn + ([variables.skill_brawn_handling_10,variables.skill_brawn_handling_20,variables.skill_brawn_handling_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_brawn_toughness_value =  variables.attribute_brawn + ([variables.skill_brawn_toughness_10,variables.skill_brawn_toughness_20,variables.skill_brawn_toughness_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_agility_coordination_value =  variables.attribute_agility + ([variables.skill_agility_coordination_10,variables.skill_agility_coordination_20,variables.skill_agility_coordination_30]|reduce((carry, v) => carry + v))*10 %}     
{% set skill_agility_thievery_value =  variables.attribute_agility + ([variables.skill_agility_thievery_10,variables.skill_agility_thievery_20,variables.skill_agility_thievery_30]|reduce((carry, v) => carry + v))*10 %}     
{% set skill_agility_stealth_value =  variables.attribute_agility + ([variables.skill_agility_stealth_10,variables.skill_agility_stealth_20,variables.skill_agility_stealth_30]|reduce((carry, v) => carry + v))*10 %}       
{% set skill_perception_awareness_value =  variables.attribute_perception + ([variables.skill_perception_awareness_10,variables.skill_perception_awareness_20,variables.skill_perception_awareness_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_perception_insight_value =  variables.attribute_perception + ([variables.skill_perception_insight_10,variables.skill_perception_insight_20,variables.skill_perception_insight_30]|reduce((carry, v) => carry + v))*10 %}    
{% set skill_perception_survival_value =  variables.attribute_perception + ([variables.skill_perception_survival_10,variables.skill_perception_survival_20,variables.skill_perception_survival_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_intelligence_folklore_value =  variables.attribute_intelligence + ([variables.skill_intelligence_folklore_10,variables.skill_intelligence_folklore_20,variables.skill_intelligence_folklore_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_intelligence_gamble_value =  variables.attribute_intelligence + ([variables.skill_intelligence_gamble_10,variables.skill_intelligence_gamble_20,variables.skill_intelligence_gamble_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_intelligence_leechcraft_value =  variables.attribute_intelligence + ([variables.skill_intelligence_leechcraft_10,variables.skill_intelligence_leechcraft_20,variables.skill_intelligence_leechcraft_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_willpower_occultism_value =  variables.attribute_willpower + ([variables.skill_willpower_occultism_10,variables.skill_willpower_occultism_20,variables.skill_willpower_occultism_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_willpower_resolve_value =  variables.attribute_willpower + ([variables.skill_willpower_resolve_10,variables.skill_willpower_resolve_20,variables.skill_willpower_resolve_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_willpower_craft_value =  variables.attribute_willpower + ([variables.skill_willpower_craft_10,variables.skill_willpower_craft_20,variables.skill_willpower_craft_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_fellowship_persuasion_value =  variables.attribute_fellowship + ([variables.skill_fellowship_persuasion_10,variables.skill_fellowship_persuasion_20,variables.skill_fellowship_persuasion_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_fellowship_disguise_value =  variables.attribute_fellowship + ([variables.skill_fellowship_disguise_10,variables.skill_fellowship_disguise_20,variables.skill_fellowship_disguise_30]|reduce((carry, v) => carry + v))*10 %}
{% set skill_fellowship_guile_value =  variables.attribute_fellowship + ([variables.skill_fellowship_guile_10,variables.skill_fellowship_guile_20,variables.skill_fellowship_guile_30]|reduce((carry, v) => carry + v))*10 %}

<!-- dodge and parry values -->
<!-- current profession selector -->
{% if variables.profession_advanced != "" %}
    {% set profession_current = variables.profession_advanced %}
{% elseif variables.profession_intermediate != "" %}
    {% set profession_current = variables.profession_intermediate %}
{% else %}
    {% set profession_current = variables.profession_basic %}
{% endif %}
<!-- peril threshold modifiers -->
{% set peril_threshold_plus_6 = variables.peril_threshold_base + 6 %}
{% set peril_threshold_plus_12 = variables.peril_threshold_base + 12 %}
{% set peril_threshold_plus_18 = variables.peril_threshold_base + 18 %}
<!-- damage threshold modifiers -->
{% if variables.shield_is_makers_mark == 1 and variables.shield_is_ruined == 0 %}
    {% set shield_damage_threshold_modifier = 1 %}
    {% else %}
    {% set shield_damage_threshold_modifier = 0 %}
{% endif %}
{% if variables.armor_is_ruined == 0 %}
    {% set armor_damage_threshold = variables.armor_dth_mod %}
{% else %}
    {% set armor_damage_threshold = 0 %}
{% endif %}
{% if variables.damage.threshold is defined and variables.damage_threshold is not empty %}
    {% set damage_threshold_temp = variables.damage_threshold %}
    {% else %}
    {% set damage_threshold_temp = attribute_brawn_bonus_final %}
{% endif %}
{% set damage_threshold_adjusted = damage_threshold_temp + armor_damage_threshold +  shield_damage_threshold_modifier %}
{% set damage_threshold_plus_6 = damage_threshold_adjusted + 6 %}
{% set damage_threshold_plus_12 = damage_threshold_adjusted + 12 %}
{% set damage_threshold_plus_18 = damage_threshold_adjusted + 18 %}
<!-- encumbrance and overage calculator -->
{% set encumbrance_weapons_array = [variables.weapon_encumbrance_1, variables.weapon_encumbrance_2, variables.weapon_encumbrance_3, variables.weapon_encumbrance_4] %}
{% set trappings_encumbrance_array = [variables.trappings_enc_1, variables.trappings_enc_2, variables.trappings_enc_3, variables.trappings_enc_4, variables.trappings_enc_5, variables.trappings_enc_6, variables.trappings_enc_7, variables.trappings_enc_8, variables.trappings_enc_9,variables.trappings_enc_10, variables.trappings_enc_11, variables.trappings_enc_12, variables.trappings_enc_13, variables.trappings_enc_14, variables.trappings_enc_15, variables.trappings_enc_16, variables.trappings_enc_17, variables.trappings_enc_18, variables.trappings_enc_19, variables.trappings_enc_20, variables.trappings_enc_21] %}
{% set reagents_encumbrance_array = [reagent_enc_1, reagent_enc_2, reagent_enc_3, reagent_enc_4, reagent_enc_5, reagent_enc_6, reagent_enc_7, reagent_enc_8, reagent_enc_9, reagent_enc_10] %}
{% set wealth_enc = ((variables.wealth_gc + variables.wealth_ss + variables.wealth_bp)/1000)|round (0,'floor') %}
{% set encumbrance_total = encumbrance_weapons_array|reduce((carry, v) => carry + v) + variables.armor_encumbrance + variables.shield_encumbrance + trappings_encumbrance_array|reduce((carry, v) => carry + v) + reagents_encumbrance_array|reduce((carry, v) => carry + v) + wealth_enc %}
<!-- encumbrance default values and calculations -->
{% if variables.encumbrance_limit is defined and variables.encumbrance_limit is not empty %}
    {% set encumbrance_limit_temp = variables.encumbrance_limit %}
    {% else %}
    {% set encumbrance_limit_temp = attribute_brawn_bonus_final +3 %}
{% endif %}
{% if encumbrance_limit_temp > encumbrance_total %}
    {% set encumbrance_overage = 0 %}
    {% else %}
    {% set encumbrance_overage = encumbrance_total - variables.encumbrance_limit %}
{% endif %}
<!-- initiative default values and calculations -->
{% if variables.initiative_base is defined and variables.initiative_base is not empty %}
    {% set initiative_base_temp = variables.initiative_base %}
    {% else %}
    {% set initiative_base_temp = attribute_perception_bonus_final +3 %}
{% endif %}
{% set initiative_current = initiative_base_temp - encumbrance_overage %}
<!-- movement calculations -->
{% if variables.movement_base is defined and variables.movement_base is not empty %}
    {% set movement_base_temp = variables.movement_base %}
    {% else %}
    {% set movement_base_temp = attribute_agility_bonus_final + 3 %}
{% endif %}
{% set movement_current = movement_base_temp - encumbrance_overage %}
<!-- Difficulty track -->
<!-- Chaos and Order Ranks -->
{% set total_corruption = variables.alignment_corruption + variables.alignment_permanent_corruption %}
{% set current_order_ranks = variables.alignment_order_ranks %}
<!-- Weapon stats -->
{% if [weapon_is_defensive_1, weapon_is_defensive_2, weapon_is_defensive_3, weapon_is_defensive_4]|reduce((carry, v) => carry + v) > 0 %}
    {% set weapon_is_defensive = 1 %}
    {% else %}
    {% set weapon_is_defensive = 0 %}
{% endif %}
<!-- end of macros -->
<div id="karta" class="container-fluid">
    <!-- Tabbing -->
    <input class="input-hidden" type="radio" name="tabs" id="tab1" checked/><label for="tab1">Personal</label>
    <input class="input-hidden" type="radio" name="tabs" id="tab3"/><label for="tab3">Attributes & Skills</label>
    <input class="input-hidden" type="radio" name="tabs" id="tab4"/><label for="tab4">Traits Talents & Gifts</label>
    <input class="input-hidden" type="radio" name="tabs" id="tab5"/><label for="tab5">Combat Profile</label>
    <input class="input-hidden" type="radio" name="tabs" id="tab6"/><label for="tab6">Trappings</label>
    <input class="input-hidden" type="radio" name="tabs" id="tab7"/><label for="tab7">Magic Profile</label>
    <input class="input-hidden" type="radio" name="tabs" id="tab8"/><label for="tab8">Advancement</label>
    <!-- TAB #1Personal -->
    <div class="tab content1">
        <div class="row">
            <div class="col-sm-12">
                <!-- TAB #1.1 -->
                <div class="row header">
                    <div class="col-sm-12">
                        <div class="row">
                            <div class="col-sm-9 card-content">
                                <div class="row card">
                                    <div class="col-sm-12">
                                        <h2>
                                        My name is&nbsp;{% if variables.name is defined %}<strong>{{ variables.name}}{% else %}Survivor{% endif %}</strong>
                                        <!-- this should loop through 3 different professions and select the highest defined -->
                                        and I'm&nbsp;<strong>a&nbsp;{% if profession_current is not empty %}{{ profession_current|title}}{% else %}Mystery{% endif %}</strong>
                                        </h2>
                                    </div>
                                    <div class="col-sm-12">
                                        I'm&nbsp;<strong>{{ variables.personal_age_group}}&nbsp;{{ variables.personal_ancestry }}&nbsp;{{ variables.personal_gender }}</strong>.&nbsp;I was born in&nbsp;<strong>{{ variables.personal_season_of_birth }}&nbsp;</strong>
                                        in the place called&nbsp;<strong>{{ variables.personal_place_of_birth}}</strong>.&nbsp;I was raised in a/an&nbsp;<strong>{{ variables.personal_upbringing}}&nbsp;</strong> home of the&nbsp;<strong>{{ variables.personal_social_class}}&nbsp;</strong> class {% if variables.personal_patron_deity is not empty %} and became a follower of&nbsp;<strong>{{ variables.personal_patron_deity}}</strong>{% endif %}.
                                        When you see me  I am of a/an&nbsp;<strong>{{ variables.personal_height}} stature</strong>&nbsp;with a/an&nbsp;<strong>{{ variables.personal_build_type}} build</strong>,<strong>&nbsp;{{ variables.personal_hair_color}} hair</strong>, 
                                        <strong>&nbsp;{{ variables.personal_eye_color}} eyes</strong>,<strong>&nbsp;{{ variables.personal_complexion}} complexion</strong>&nbsp;and&nbsp;<strong>{{ variables.personal_distinguishing_marks_1}}</strong>.
                                        My life changed the day that{% if variables.personal_brush_with_death is defined and variables.personal_brush_with_death is not empty %}{{ variables.personal_brush_with_death}}{% else %}<i><strong>&nbsp;is shrouded in the fog of war</strong></i>{% endif %}.
                                        Yet I lived to tell the tale.
                                    </div>
                                </div>
                                <div class="row card">
                                    <div class="col-sm-12"><strong>Languages:</strong> {{ variables.personal_language }}</div>
                                </div>
                                <div class="row card">
                                    <div class="col-sm-12"><strong>Inner Strength:</strong> {{ variables.alignment_inner_strength }}</div>
                                    <div class="col-sm-12">
                                        <div class="card-info-label"><i>Did you call upon one of your Inner Strengths 5 RP</i></div>
                                    </div>
                                </div>
                                <div class="row card">
                                    <div class="col-sm-12"><strong>Tragic Flaw:</strong> {{ variables.alignment_tragic_flaw }}</div>
                                    <div class="col-sm-12">
                                        <div class="card-info-label"><i>Did you call upon one of your Tragic Flaws 5 RP</i></div>
                                    </div>
                                </div>
                                <div class="row card">
                                    <div class="col-sm-12"><strong>In my adventures I have been tained by corruption:</strong>
                                    {% for i in 1..9 %}{% if total_corruption >= i %}&nbsp;<i class="fas fa-circle"></i> {% else %}&nbsp;<i class="far fa-circle"></i>{% endif %}{% endfor %}
                                    &nbsp;<strong>Gain Malignancy</strong>
                                    </div>
                                    <div class="col-sm-12"><strong>And the world has left a mark on me:</strong></div>
                                    <div class="col-sm-12">{% if malignancies_and_scars is not empty %} {{ variable.malignancies_and_scars |nl2br}}{% else %} ... {% endif %}</div>
                                    <div class="col-sm-12"><strong>Permanent Corrupton</strong>&nbsp;{% if permanent_corruption == 0 %} 0 {% else %} {{ permanent_corruption }} {% endif %}</div>
                                </div>
                            </div>    
                            <div class="col-sm-3 card-mt3">{% if variables.imageid is defined and variables.imageid > 0 %}[img:{{variables.imageid}}|nolink]{% endif %} </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-6">
                <div class="row">
                    <div class="col-sm-12 card">
                        <div class="row"><div class="col-sm-12 card-title">Attributes And Skills</div></div>
                        <div class="row">
