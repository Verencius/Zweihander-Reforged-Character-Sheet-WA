<!-- talismans -->
{# === TALISMAN BONUSES === #}
{% set skills = [
  'Athletics', 'Awareness', 'Blackpowder', 'Coordination', 'Craft',
  'Disguise', 'Folklore', 'Gamble', 'Guile', 'Handling',
  'Insight', 'Leechcraft', 'Melee', 'Occultism', 'Persuasion',
  'Ranged', 'Resolve', 'Stealth', 'Survival', 'Thievery', 'Toughness'
] %}
{# Build objects array from variables #}
{% set talisman_objects = [] %}
{% for i in 2..10 %}
  {% set talisman_objects = talisman_objects | merge([variables["object_" ~ i]|default('')|lower]) %}
{% endfor %}
{# Build result array — index matches skills array #}
{% set talisman_bonuses = [] %}
{% for skill in skills %}
  {% set found = [false] %}
  {% for obj in talisman_objects %}
    {% if obj is not empty and ('talisman of ' ~ skill|lower) in obj %}
      {% set found = [true] %}
    {% endif %}
  {% endfor %}
  {% set talisman_bonuses = talisman_bonuses | merge([found[0] ? 5 : 0]) %}
{% endfor %}
{# talisman_bonuses index reference: #}
{# 0=Athletics, 1=Awareness, 2=Blackpowder, 3=Coordination, 4=Craft    #}
{# 5=Disguise,  6=Folklore,  7=Gamble,      8=Guile,        9=Handling  #}
{# 10=Insight,  11=Leechcraft, 12=Melee,    13=Occultism,   14=Persuasion #}
{# 15=Ranged,   16=Resolve,   17=Stealth,   18=Survival,    19=Thievery  #}
{# 20=Toughness #}
<!-- athletics -->
{% set athletics_count = 0 %}
{% for tier in ['basic', 'intermediate', 'advanced'] %}
    {% for i in 1..6 %}
        {% set skill = attribute(variables, "profession_" ~ tier ~ "_skill_" ~ i)|default('') %}
        {% set toggle = attribute(variables, "profession_" ~ tier ~ "_toggle_" ~ i)|default(0) %}
        
        {% if skill == "Athletics" and toggle == 1 %}
            {% set athletics_count = athletics_count + 1 %}
        {% endif %}
    {% endfor %}
{% endfor %}
{% set athletics_advance = athletics_count > 3 ? 3 : athletics_count %}
{% set skill_athletics_total = attribute_brawn_final + (athletics_advance * 10) + talisman_bonuses[0] %}
