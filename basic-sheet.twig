    {% for i in 1..6 %}
        {% set skill = attribute(variables, "profession_" ~ tier ~ "_skill_" ~ i)|default('') %}
        {% set toggle = attribute(variables, "profession_" ~ tier ~ "_toggle_" ~ i)|default(0) %}
        {% if skill == "Melee" and toggle == 1 %}
            {% set melee_count = melee_count + 1 %}
        {% endif %}
    {% endfor %}
{% endfor %}
{# 3. Cap the bonus at 3 (simulating your if/else check) #}
{% set melee_advance = melee_count > 3 ? 3 : melee_count %}
